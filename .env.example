# Copy to .env for local overrides (never commit real secrets)

# Use mock metrics / store (demo only — keep false for real training)
USE_MOCK=false

# If set, mutating APIs require header: X-API-Token: <value>
# PROXYGUARD_TOKEN=change-me

# Max CSV upload size in bytes (default 20MB)
# PROXYGUARD_MAX_UPLOAD_BYTES=20971520

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
